{
  "manifest_version": 3,
  "name": "Parallel Prompts",
  "version": "1.0.0",
  "description": "Upload CSVs of prompts and run them in parallel across web LLMs (ChatGPT, Claude, Gemini, DeepSeek, Qwen, etc.) with per-row model selection, rate-limit detection, and CSV export.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "downloads",
    "activeTab",
    "windows",
    "nativeMessaging",
    "alarms"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://chat.deepseek.com/*",
    "https://chat.qwen.ai/*",
    "https://chat.qwenlm.ai/*",
    "https://www.perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://grok.com/*",
    "https://x.com/i/grok*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "Parallel Prompts",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://chat.deepseek.com/*",
        "https://chat.qwen.ai/*",
        "https://chat.qwenlm.ai/*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://grok.com/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dashboard/dashboard.html",
        "popup/popup.html",
        "lib/papaparse.min.js",
        "shared/llms.js",
        "pyodide-runner/runner.html",
        "pyodide-runner/runner.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "sandbox": {
    "pages": ["pyodide-runner/runner.html"]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';",
    "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; connect-src 'self' https://cdn.jsdelivr.net https://pypi.org https://files.pythonhosted.org https://*.pypi.org; style-src 'self' 'unsafe-inline'; img-src 'self' data:;"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
